RECIDIVIZ_ENV_NAME = dev

# ----------------------------------------------- #
# To deploy in GCP, you need to set the following
# ----------------------------------------------- #
RECIDIVIZ_DEPLOY_ENV=gcp
RECIDIVIZ_GCP_DB_INSTANCE_NAME=<PROJECT_ID>:<REGION>:<INSTANCE_NAME>
REDIS_URL=redis://<REDIS_HOST>:<REDIS_PORT>


# ----------------------------------------------- #
# Environment
# ----------------------------------------------- #
# RECIDIVIZ_ALLOW_EXPERIMENTS=false
# RECIDIVIZ_VCR_CLIENT_INTAKE=false

# ----------------------------------------------- #
# Google Cloud Configuration
# ----------------------------------------------- #
RECIDIVIZ_BQ_PROJECT_ID=recidiviz-rnd-planner
RECIDIVIZ_BQ_DATASET=reentry

# BigQuery Tables (optional, defaults to dev tables)
RECIDIVIZ_BQ_CASE_MANAGER_TABLE=case_manager_dev
RECIDIVIZ_BQ_SUPERVISION_OFFICER_TABLE=supervision_officer_dev
RECIDIVIZ_BQ_CLIENT_TABLE=client_dev

# Google Cloud Bucket for Audio Recordings
RECIDIVIZ_GCS_BUCKET_NAME=your-audio-recordings-bucket

# Deepgram api key
RECIDIVIZ_DEEPGRAM_API_KEY=deepgram-api-key

# Transcription service provider, deepgram or gcp
RECIDIVIZ_DIARIZATION_SERVICE=deepgram

# ----------------------------------------------- #
# Database credentials
# ----------------------------------------------- #
RECIDIVIZ_POSTGRES_USER=postgres
RECIDIVIZ_POSTGRES_PASSWORD=password
RECIDIVIZ_POSTGRES_SERVER=postgres # or localhost
RECIDIVIZ_POSTGRES_PORT=5432
RECIDIVIZ_POSTGRES_DB=recidiviz

# ----------------------------------------------- #
# PGAdmin credentials
# ----------------------------------------------- #
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin

# ----------------------------------------------- #
# LLM
# ----------------------------------------------- #
RECIDIVIZ_OPENAI_API_KEY=open-ai-apikey
RECIDIVIZ_ANTHROPIC_API_KEY=

# Optional, if you want to override the default models

# RECIDIVIZ_DT_MODEL_PROVIDER=openai
# RECIDIVIZ_DT_MODEL_NAME=gpt-4o-mini
# RECIDIVIZ_DT_MODEL_VERSION=""

# RECIDIVIZ_GEN_MODEL_PROVIDER=openai
# RECIDIVIZ_GEN_MODEL_NAME=gpt-4o
# RECIDIVIZ_GEN_MODEL_VERSION=""

# RECIDIVIZ_EVAL_MODEL_PROVIDER=openai
# RECIDIVIZ_EVAL_MODEL_NAME=gpt-4o
# RECIDIVIZ_EVAL_MODEL_VERSION=""

# ----------------------------------------------- #
# LLM traces
# ----------------------------------------------- #
RECIDIVIZ_LANGCHAIN_API_KEY=
RECIDIVIZ_LANGCHAIN_TRACING_V2=true
RECIDIVIZ_LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
RECIDIVIZ_LANGCHAIN_PROJECT="dev-recidiviz"

# ----------------------------------------------- #
# Resources API
# ----------------------------------------------- #
RECIDIVIZ_RESOURCE_API_URL=
RECIDIVIZ_RESOURCE_API_KEY=



# ----------------------------------------------- #
RECIDIVIZ_ALLOWED_ORIGINS=http://localhost:3000


# ----------------------------------------------- #
# AUTH0 AUTHENTICATION MIDDLEWARE
# ----------------------------------------------- #
RECIDIVIZ_ENABLE_AUTH_MIDDLEWARE = False
RECIDIVIZ_AUTH0_AUDIENCE=
RECIDIVIZ_AUTH0_CLIENT_ID=
RECIDIVIZ_AUTH0_DOMAIN=

RECIDIVIZ_JWT_ALGORITHM
RECIDIVIZ_JWT_SECRET_KEY


# ----------------------------------------------- #
# RECAPTCHA CONFIGURATION
# ----------------------------------------------- #
RECIDIVIZ_RECAPTCHA_SECRET_KEY=

# ----------------------------------------------- #
# SENTRY ERROR TRACKING
# ----------------------------------------------- #
RECIDIVIZ_SENTRY_DSN=

RECIDIVIZ_ENVIRONMENT_TEST_FEATURE="dev,demo"
