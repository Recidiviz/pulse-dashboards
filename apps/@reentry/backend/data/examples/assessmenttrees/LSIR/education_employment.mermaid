    B --> B3[Employed]
    B --> B4[Education]
    B --> B5[Education and Employment]
    B --> B6[Retiree]
    B --> B7[Homemaker]
    B --> B8[SSD/SSI]
    B --> B999[Unclear]

    B999 --> STOP[End: not enough info to start]

    B1 & B2 --> BYes{Count:Q11-1}
    B3 & B4 & B5 & B6 & B7 & B8 --> BNo{Count:Q11-0}

    B1 & B2 & B3 --> C{Q12}
    C --> C1[Yes]
    C --> C2[No]
    C --> C999[Unclear]

    C1 --> CYes{Count:Q12-1}
    C2 & B4 & B5 & B6 & B7 & B8 --> CNo{Count:Q12-0}

