{
  "name": "@reentry/frontend",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/@reentry/frontend/app",
  "projectType": "application",
  "tags": ["scope:client"],
  "targets": {
    "load-env-files": {
      "executor": "nx:run-commands",
      "options": {
        "command": "../../../tools/load_env_files.sh --env env_reentry_frontend  --env_demo env_demo_reentry_frontend --env_staging env_staging_reentry_frontend --env_prod env_prod_reentry_frontend",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["tsc -p ./tsconfig.json"],
        "cwd": "{projectRoot}"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next dev",
        "cwd": "{projectRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'No tests yet'"
      }
    },
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{options.outputPath}"],
      "dependsOn": ["load-env-files", "^prisma-generate"],
      "options": {
        "outputPath": "dist/apps/@reentry/frontend",
        "cwd": "{workspaceRoot}"
      },
      "configurations": {
        "dev": {},
        "staging": {},
        "demo": {},
        "production": {}
      },
      "defaultConfiguration": "dev"
    },
    "copy-correct-env": {
      "dependsOn": ["build"],
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}"
      },
      "configurations": {
        "dev": {
          "command": "cp apps/@reentry/frontend/.env dist/apps/@reentry/frontend/.next/standalone/apps/@reentry/frontend/.env"
        },
        "staging": {
          "command": "cp apps/@reentry/frontend/.env.staging dist/apps/@reentry/frontend/.next/standalone/apps/@reentry/frontend/.env.production"
        },
        "demo": {
          "command": "cp apps/@reentry/frontend/.env.demo dist/apps/@reentry/frontend/.next/standalone/apps/@reentry/frontend/.env.production"
        },
        "production": {
          "command": "cp apps/@reentry/frontend/.env.production dist/apps/@reentry/frontend/.next/standalone/apps/@reentry/frontend/.env.production"
        }
      },
      "defaultConfiguration": "dev"
    },
    "container": {
      "executor": "@nx-tools/nx-container:build",
      "dependsOn": ["copy-correct-env"],
      "cwd": "{projectRoot}",
      "options": {
        "engine": "docker",
        "file": "{projectRoot}/Dockerfile.gcp",
        "platforms": ["linux/amd64"]
      },
      "configurations": {
        "dev": {
          "push": false
        },
        "staging": {
          "push": true,
          "tags": [
            "gcr.io/recidiviz-rnd-planner/frontend-staging:$COMMIT_SHA",
            "gcr.io/recidiviz-rnd-planner/frontend-staging:latest"
          ]
        },
        "cherry-pick": {
          "push": true,
          "tags": [
            "gcr.io/recidiviz-rnd-planner/frontend-production:$COMMIT_SHA"
          ]
        },
        "production": {
          "push": true,
          "tags": [
            "gcr.io/recidiviz-rnd-planner/frontend-production:$COMMIT_SHA"
          ]
        },
        "demo": {
          "push": true,
          "tags": ["gcr.io/recidiviz-rnd-planner/frontend-demo:$COMMIT_SHA"]
        }
      },
      "defaultConfiguration": "dev"
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}"
      },
      "dependsOn": ["container"],
      "configurations": {
        "staging": {
          "command": "gcloud run deploy frontend-staging --image gcr.io/recidiviz-rnd-planner/frontend-staging:$COMMIT_SHA --region us-central1 --platform managed --allow-unauthenticated --service-account reentry-server-staging@recidiviz-rnd-planner.iam.gserviceaccount.com --project recidiviz-rnd-planner"
        },
        "cherry-pick": {
          "command": "gcloud run deploy frontend-prod --image gcr.io/recidiviz-rnd-planner/frontend-production:$COMMIT_SHA --region us-central1 --platform managed --allow-unauthenticated --service-account reentry-server@recidiviz-rnd-planner.iam.gserviceaccount.com --project recidiviz-rnd-planner"
        },
        "production": {
          "command": "gcloud run deploy frontend-prod --image gcr.io/recidiviz-rnd-planner/frontend-production:$COMMIT_SHA --region us-central1 --platform managed --allow-unauthenticated --service-account reentry-server@recidiviz-rnd-planner.iam.gserviceaccount.com --project recidiviz-rnd-planner"
        },
        "demo": {
          "command": "gcloud run deploy frontend-demo --image gcr.io/recidiviz-rnd-planner/frontend-demo:$COMMIT_SHA --region us-central1 --platform managed --allow-unauthenticated --project recidiviz-rnd-planner"
        }
      },
      "defaultConfiguration": "demo"
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next start",
        "cwd": "{projectRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/apps/@reentry/frontend"],
      "cache": true,
      "options": {
        "command": "vitest",
        "cwd": "{projectRoot}"
      }
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/coverage/apps/@reentry/frontend-integration"
      ],
      "cache": false,
      "options": {
        "command": "vitest --config vitest.integration.config.mts",
        "cwd": "{projectRoot}"
      }
    },
    "openapi": {
      "executor": "nx:run-commands",
      "options": {
        "command": "openapi-typescript http://127.0.0.1:8000/openapi.json -o app/recidiviz-schema.d.ts",
        "cwd": "{projectRoot}"
      }
    }
  }
}
