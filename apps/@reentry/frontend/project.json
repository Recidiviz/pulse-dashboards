{
  "name": "@reentry/frontend",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/@reentry/frontend/app",
  "projectType": "application",
  "tags": ["scope:client"],
  "targets": {
    "lint-files": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint --max-warnings 0 --no-warn-ignored",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["tsc -p ./tsconfig.json"],
        "cwd": "{projectRoot}"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next dev",
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next build",
        "cwd": "{projectRoot}"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next start",
        "cwd": "{projectRoot}"
      }
    },
    "openapi": {
      "executor": "nx:run-commands",
      "options": {
        "command": "openapi-typescript http://127.0.0.1:8000/openapi.json -o app/recidiviz-schema.d.ts",
        "cwd": "{projectRoot}"
      }
    }
  }
}
