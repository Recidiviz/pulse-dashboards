{
  "name": "@reentry/frontend",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/@reentry/frontend/app",
  "projectType": "application",
  "tags": ["scope:client"],
  "targets": {
    "load-env-files": {
      "executor": "nx:run-commands",
      "options": {
        "command": "../../../tools/load_env_files.sh --env env_reentry_frontend --env_dev_gcp env_dev_gcp_reentry_frontend --env_pilot env_pilot_reentry_frontend --env_demo env_demo_reentry_frontend --env_staging env_staging_reentry_frontend --env_prod env_prod_reentry_frontend",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["tsc -p ./tsconfig.json"],
        "cwd": "{projectRoot}"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "dependsOn": ["load-env-files"],
      "options": {
        "command": "next dev",
        "cwd": "{projectRoot}"
      }
    },
    "dev:with-staging-proxy": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["node proxy-staging.js", "next dev"],
        "parallel": true,
        "cwd": "{projectRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'No tests yet'"
      }
    },
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{options.outputPath}"],
      "dependsOn": ["load-env-files", "^prisma-generate"],
      "options": {
        "outputPath": "dist/apps/@reentry/frontend",
        "cwd": "{workspaceRoot}"
      },
      "configurations": {
        "dev": {},
        "dev_gcp": {},
        "staging": {},
        "demo": {},
        "pilot": {},
        "production": {},
        "cherry-pick": {}
      },
      "defaultConfiguration": "dev"
    },
    "copy-correct-env": {
      "dependsOn": ["build"],
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}"
      },
      "configurations": {
        "dev": {
          "command": "cp apps/@reentry/frontend/.env dist/apps/@reentry/frontend/.next/standalone/apps/@reentry/frontend/.env"
        },
        "dev_gcp": {
          "command": "cp apps/@reentry/frontend/.env.dev_gcp dist/apps/@reentry/frontend/.next/standalone/apps/@reentry/frontend/.env.production"
        },
        "staging": {
          "command": "cp apps/@reentry/frontend/.env.staging dist/apps/@reentry/frontend/.next/standalone/apps/@reentry/frontend/.env.production"
        },
        "demo": {
          "command": "cp apps/@reentry/frontend/.env.demo dist/apps/@reentry/frontend/.next/standalone/apps/@reentry/frontend/.env.production"
        },
        "pilot": {
          "command": "cp apps/@reentry/frontend/.env.pilot dist/apps/@reentry/frontend/.next/standalone/apps/@reentry/frontend/.env.production"
        },
        "production": {
          "command": "cp apps/@reentry/frontend/.env.production dist/apps/@reentry/frontend/.next/standalone/apps/@reentry/frontend/.env.production"
        },
        "cherry-pick": {
          "command": "cp apps/@reentry/frontend/.env.production dist/apps/@reentry/frontend/.next/standalone/apps/@reentry/frontend/.env.production"
        }
      },
      "defaultConfiguration": "dev"
    },
    "container": {
      "_note": "dev_gcp and pilot skip this step and build the container directly in the deploy step using docker commands for more control over build flags",
      "executor": "@nx-tools/nx-container:build",
      "dependsOn": ["copy-correct-env"],
      "cwd": "{projectRoot}",
      "options": {
        "engine": "docker",
        "file": "{projectRoot}/Dockerfile.gcp",
        "platforms": ["linux/amd64"]
      },
      "configurations": {
        "dev": {
          "push": false
        },
        "staging": {
          "push": true,
          "tags": [
            "gcr.io/recidiviz-rnd-planner/frontend-staging:$COMMIT_SHA",
            "gcr.io/recidiviz-rnd-planner/frontend-staging:latest"
          ]
        },
        "cherry-pick": {
          "push": true,
          "tags": [
            "gcr.io/recidiviz-rnd-planner/frontend-production:$COMMIT_SHA"
          ]
        },
        "production": {
          "push": true,
          "tags": [
            "gcr.io/recidiviz-rnd-planner/frontend-production:$COMMIT_SHA"
          ]
        },
        "demo": {
          "push": true,
          "tags": ["gcr.io/recidiviz-rnd-planner/frontend-demo:$COMMIT_SHA"]
        }
      },
      "defaultConfiguration": "dev"
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "parallel": false
      },
      "dependsOn": ["container"],
      "configurations": {
        "staging": {
          "commands": [
            "gcloud run deploy frontend-staging --image gcr.io/recidiviz-rnd-planner/frontend-staging:$COMMIT_SHA --region us-central1 --platform managed --allow-unauthenticated --service-account reentry-server-staging@recidiviz-rnd-planner.iam.gserviceaccount.com --project recidiviz-rnd-planner",
            "gcloud -q run services update-traffic frontend-staging --project recidiviz-rnd-planner --region us-central1 --to-latest"
          ]
        },
        "cherry-pick": {
          "commands": [
            "gcloud run deploy frontend-prod --image gcr.io/recidiviz-rnd-planner/frontend-production:$COMMIT_SHA --region us-central1 --platform managed --allow-unauthenticated --service-account reentry-server@recidiviz-rnd-planner.iam.gserviceaccount.com --project recidiviz-rnd-planner",
            "gcloud -q run services update-traffic frontend-prod --project recidiviz-rnd-planner --region us-central1 --to-latest"
          ]
        },
        "production": {
          "commands": [
            "gcloud run deploy frontend-prod --image gcr.io/recidiviz-rnd-planner/frontend-production:$COMMIT_SHA --region us-central1 --platform managed --allow-unauthenticated --service-account reentry-server@recidiviz-rnd-planner.iam.gserviceaccount.com --project recidiviz-rnd-planner",
            "gcloud -q run services update-traffic frontend-prod --project recidiviz-rnd-planner --region us-central1 --to-latest"
          ]
        },
        "demo": {
          "commands": [
            "gcloud run deploy frontend-demo --image gcr.io/recidiviz-rnd-planner/frontend-demo:$COMMIT_SHA --region us-central1 --platform managed --allow-unauthenticated --project recidiviz-rnd-planner",
            "gcloud -q run services update-traffic frontend-demo --project recidiviz-rnd-planner --region us-central1 --to-latest"
          ]
        },
        "dev_gcp": {
          "dependsOn": ["copy-correct-env"],
          "cwd": "{workspaceRoot}",
          "commands": [
            "docker build --platform linux/amd64 --provenance=false -t gcr.io/recidiviz-rnd-planner/frontend-dev:$COMMIT_SHA -f apps/@reentry/frontend/Dockerfile.gcp .",
            "docker push gcr.io/recidiviz-rnd-planner/frontend-dev:$COMMIT_SHA",
            "gcloud run deploy frontend-dev --image gcr.io/recidiviz-rnd-planner/frontend-dev:$COMMIT_SHA --region us-central1 --platform managed --allow-unauthenticated --project recidiviz-rnd-planner",
            "gcloud -q run services update-traffic frontend-dev --project recidiviz-rnd-planner --region us-central1 --to-latest"
          ]
        },
        "pilot": {
          "dependsOn": ["copy-correct-env"],
          "cwd": "{workspaceRoot}",
          "commands": [
            "docker build --platform linux/amd64 --provenance=false -t gcr.io/recidiviz-rnd-planner/frontend-pilot:$COMMIT_SHA -f apps/@reentry/frontend/Dockerfile.gcp .",
            "docker push gcr.io/recidiviz-rnd-planner/frontend-pilot:$COMMIT_SHA",
            "gcloud run deploy frontend-pilot --image gcr.io/recidiviz-rnd-planner/frontend-pilot:$COMMIT_SHA --region us-central1 --platform managed --allow-unauthenticated --project recidiviz-rnd-planner",
            "gcloud -q run services update-traffic frontend-pilot --project recidiviz-rnd-planner --region us-central1 --to-latest"
          ]
        }
      },
      "defaultConfiguration": "demo"
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next start",
        "cwd": "{projectRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/apps/@reentry/frontend"],
      "cache": true,
      "options": {
        "command": "vitest",
        "cwd": "{projectRoot}"
      }
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/coverage/apps/@reentry/frontend-integration"
      ],
      "cache": false,
      "options": {
        "command": "vitest --config vitest.integration.config.mts",
        "cwd": "{projectRoot}"
      }
    },
    "openapi": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./tools/generate-openapi-schema.sh",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
