{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "types": ["vitest/globals", "vitest/importMeta", "node", "vitest"]
  },
  "include": [
    "../../libs/@jii/**/*.d.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/testUtils.ts",
    "src/**/__tests__/*.ts",
    "src/**/__tests__/*.tsx",
    "src/**/*.d.ts",
    "vite.config.mts",
    "src/setupTests.ts",
    "src/setupTestsGlobal.ts"
  ]
}
