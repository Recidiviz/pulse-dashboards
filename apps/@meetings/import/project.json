{
  "name": "@meetings/import",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/@meetings/import/src",
  "projectType": "application",
  "tags": ["meetings", "scope:server"],
  "targets": {
    "test-zod": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx test-zod/index.ts",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "projects": ["@meetings/prisma"],
          "target": "prisma-generate"
        }
      ],
      "options": {
        "commands": [
          "tsc -p ./tsconfig.app.json",
          "tsc -p ./tsconfig.spec.json",
          "tsc -p ./tsconfig.zod.json"
        ],
        "cwd": "{projectRoot}"
      }
    },
    "create-base-package-json": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx tools/create-base-package-json.mts {projectRoot}",
        "cwd": "{workspaceRoot}"
      }
    },
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "dependsOn": [
        "create-base-package-json",
        {
          "projects": ["@meetings/prisma"],
          "target": "prisma-generate"
        }
      ],
      "options": {
        "platform": "node",
        "outputPath": "{workspaceRoot}/dist/apps/{projectName}",
        "bundle": true,
        "main": "{projectRoot}/src/main.ts",
        "additionalEntryPoints": ["{projectRoot}/src/sentry/index.ts"],
        "sourcemap": true,
        "tsConfig": "{projectRoot}/tsconfig.app.json",
        "generatePackageJson": true,
        "target": "node22",
        "minify": true,
        "external": ["@prisma/client"],
        "assets": ["{workspaceRoot}/.yarnrc.yml"]
      },
      "configurations": {
        "dev": {
          "minify": false,
          "sourcemap": false
        },
        "staging": {},
        "cherry-pick": {},
        "preview": {}
      },
      "defaultConfiguration": "dev"
    },
    "requires-sops-env:test": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "projects": ["@meetings/prisma"],
          "target": "prisma-generate"
        },
        {
          "projects": ["@meetings/prisma"],
          "target": "docker"
        },
        {
          "projects": ["@meetings/prisma"],
          "target": "prisma-deploy"
        }
      ],
      "outputs": ["{workspaceRoot}/coverage/apps/@meetings/import"],
      "cache": true,
      "options": {
        "command": "vitest",
        "cwd": "{projectRoot}"
      },
      "defaultConfiguration": "dev",
      "configurations": {
        "dev": {},
        "test": {},
        "ci": {}
      }
    },
    "requires-sops-env:upload-sourcemaps": {},
    "container": {
      "executor": "@nx-tools/nx-container:build",
      "dependsOn": ["upload-sourcemaps"],
      "cwd": "{projectRoot}",
      "options": {
        "engine": "docker",
        "platforms": ["linux/amd64"]
      },
      "configurations": {
        "dev": {
          "push": false
        },
        "staging": {
          "push": true,
          "tags": [
            "us-central1-docker.pkg.dev/recidiviz-dashboard-staging/meetings/meetings-data-import:$COMMIT_SHA",
            "us-central1-docker.pkg.dev/recidiviz-dashboard-staging/meetings/meetings-data-import:latest"
          ]
        },
        "cherry-pick": {
          "push": true,
          "tags": [
            "us-central1-docker.pkg.dev/recidiviz-dashboard-staging/meetings/meetings-data-import:$COMMIT_SHA"
          ]
        },
        "preview": {
          "push": true,
          "tags": [
            "us-central1-docker.pkg.dev/recidiviz-dashboard-staging/meetings/meetings-data-import-preview:$VERSION"
          ]
        }
      },
      "defaultConfiguration": "dev"
    },
    "deploy-preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "gcloud run jobs deploy s-data-import-preview-$VERSION --image us-central1-docker.pkg.dev/recidiviz-dashboard-staging/meetings/meetings-data-import-preview:$VERSION --region us-central1 --set-env-vars IMPORT_BUCKET_ID=$IMPORT_BUCKET_ID,DATABASE_USER=$DATABASE_USER,DATABASE_PASSWORD=$DATABASE_PASSWORD,DATABASE_INSTANCE_CONNECTION_NAME=$DATABASE_INSTANCE_CONNECTION_NAME --project recidiviz-dashboard-staging --set-cloudsql-instances recidiviz-dashboard-staging:us-central1:r-db-preview-$VERSION --service-account meetings@recidiviz-dashboard-staging.iam.gserviceaccount.com"
      }
    }
  }
}
