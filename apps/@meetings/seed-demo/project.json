{
  "name": "@meetings/seed-demo",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/@meetings/seed-demo/src",
  "projectType": "application",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "projects": ["@meetings/prisma"],
          "target": "prisma-generate"
        }
      ],
      "options": {
        "commands": [
          "tsc -p ./tsconfig.app.json",
          "tsc -p ./tsconfig.spec.json"
        ],
        "cwd": "{projectRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "echo 'No tests for this library'",
        "cwd": "{projectRoot}"
      }
    },
    "create-base-package-json": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx tools/create-base-package-json.mts {projectRoot}",
        "cwd": "{workspaceRoot}"
      }
    },
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "dependsOn": [
        "create-base-package-json",
        {
          "projects": ["@meetings/prisma"],
          "target": "prisma-generate"
        }
      ],
      "options": {
        "platform": "node",
        "outputPath": "{workspaceRoot}/dist/apps/{projectName}",
        "bundle": true,
        "main": "{projectRoot}/src/seed.ts",
        "tsConfig": "{projectRoot}/tsconfig.app.json",
        "generatePackageJson": true,
        "target": "node20",
        "minify": true,
        "external": ["@prisma/client"],
        "assets": ["{workspaceRoot}/.yarnrc.yml"]
      }
    },
    "container": {
      "executor": "@nx-tools/nx-container:build",
      "dependsOn": ["build"],
      "cwd": "{projectRoot}",
      "options": {
        "engine": "docker",
        "platforms": ["linux/amd64"]
      },
      "configurations": {
        "dev": {
          "push": false
        },
        "staging": {
          "push": true,
          "tags": [
            "us-central1-docker.pkg.dev/recidiviz-dashboard-staging/meetings/meetings-seed-demo:$COMMIT_SHA",
            "us-central1-docker.pkg.dev/recidiviz-dashboard-staging/meetings/meetings-seed-demo:latest"
          ]
        }
      },
      "defaultConfiguration": "dev"
    }
  },
  "tags": ["meetings", "scope:server"]
}
