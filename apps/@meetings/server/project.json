{
  "name": "@meetings/server",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/@meetings/server/src",
  "projectType": "application",
  "tags": ["meetings", "scope:server"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "projects": ["@meetings/prisma"],
          "target": "prisma-generate"
        }
      ],
      "options": {
        "commands": [
          "tsc -p ./tsconfig.app.json",
          "tsc -p ./tsconfig.spec.json"
        ],
        "cwd": "{projectRoot}"
      }
    },
    "requires-sops-env:dev": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "checkpointer-setup",
        {
          "projects": ["@meetings/prisma"],
          "target": "docker"
        }
      ],
      "options": {
        "command": "GOOGLE_APPLICATION_CREDENTIALS=recidiviz-dashboard-staging-22598baea1a7.json vite-node --watch src/main.ts",
        "cwd": "{projectRoot}"
      }
    },
    "create-base-package-json": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx tools/create-base-package-json.mts {projectRoot}",
        "cwd": "{workspaceRoot}"
      }
    },
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "dependsOn": [
        "create-base-package-json",
        {
          "projects": ["@meetings/prisma"],
          "target": "prisma-generate"
        },
        "load-env-files"
      ],
      "options": {
        "platform": "node",
        "outputPath": "{workspaceRoot}/dist/apps/{projectName}",
        "bundle": true,
        "main": "{projectRoot}/src/main.ts",
        "additionalEntryPoints": [
          "{projectRoot}/src/sentry/index.ts",
          "{projectRoot}/src/jobs/meeting-artifact-cleanup.ts"
        ],
        "sourcemap": true,
        "tsConfig": "{projectRoot}/tsconfig.app.json",
        "generatePackageJson": true,
        "target": "node20",
        "minify": true,
        "external": ["@prisma/client"],
        "assets": [
          {
            "glob": "prisma/schema.prisma",
            "input": "{workspaceRoot}/libs/@meetings/prisma",
            "output": "."
          },
          {
            "glob": "prisma/migrations/**/*",
            "input": "{workspaceRoot}/libs/@meetings/prisma",
            "output": "."
          },
          "{projectRoot}/scripts/*",
          "{workspaceRoot}/.yarnrc.yml"
        ]
      },
      "configurations": {
        "dev": {
          "minify": false,
          "sourcemap": false
        },
        "staging": {},
        "cherry-pick": {},
        "preview": {}
      },
      "defaultConfiguration": "dev"
    },
    "preview": {
      "executor": "@nx/vite:preview-server",
      "dependsOn": [
        {
          "projects": ["@meetings/prisma"],
          "target": "docker"
        },
        {
          "projects": ["@meetings/prisma"],
          "target": "prisma-seed"
        },
        "build"
      ],
      "options": {
        "buildTarget": "@meetings/server:build"
      }
    },
    "requires-sops-env:test": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "projects": ["@meetings/prisma"],
          "target": "prisma-generate"
        },
        {
          "projects": ["@meetings/prisma"],
          "target": "docker"
        }
      ],
      "outputs": ["{workspaceRoot}/coverage/apps/meetings"],
      "cache": true,
      "options": {
        "command": "nx prisma-deploy @meetings/prisma -c test && cd apps/@meetings/server && vitest",
        "cwd": "{workspaceRoot}"
      },
      "configurations": {
        "test": {}
      },
      "defaultConfiguration": "test"
    },
    "requires-sops-env:upload-sourcemaps": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "inputs": [],
      "options": {
        "env": {
          "BUILD_OUTPUT_PATH": "{workspaceRoot}/dist/apps/{projectName}"
        },
        "cwd": "{workspaceRoot}",
        "command": "sentry-cli sourcemaps inject $BUILD_OUTPUT_PATH && sentry-cli sourcemaps upload $BUILD_OUTPUT_PATH && find $BUILD_OUTPUT_PATH -type f -name \"*.js.map\" -delete"
      },
      "configurations": {
        "dev": {
          "command": "echo 'No sourcemaps to upload in dev mode.'"
        },
        "staging": {},
        "cherry-pick": {},
        "preview": {}
      },
      "defaultConfiguration": "dev"
    },
    "container": {
      "executor": "@nx-tools/nx-container:build",
      "dependsOn": ["upload-sourcemaps"],
      "cwd": "{projectRoot}",
      "options": {
        "engine": "docker",
        "platforms": ["linux/amd64"]
      },
      "configurations": {
        "dev": {
          "push": false
        },
        "staging": {
          "push": true,
          "tags": [
            "us-central1-docker.pkg.dev/recidiviz-dashboard-staging/meetings/meetings-server:$COMMIT_SHA",
            "us-central1-docker.pkg.dev/recidiviz-dashboard-staging/meetings/meetings-server:latest"
          ]
        },
        "cherry-pick": {
          "push": true,
          "tags": [
            "us-central1-docker.pkg.dev/recidiviz-dashboard-staging/meetings/meetings-server:$COMMIT_SHA"
          ]
        },
        "preview": {
          "push": true,
          "tags": [
            "us-central1-docker.pkg.dev/recidiviz-dashboard-staging/meetings/meetings-server-preview:$VERSION"
          ]
        },
        "demo": {
          "push": true,
          "tags": [
            "us-central1-docker.pkg.dev/recidiviz-dashboard-staging/meetings/meetings-server:$COMMIT_SHA"
          ]
        }
      },
      "defaultConfiguration": "dev"
    },
    "create-preview-db": {
      "executor": "nx:run-commands",
      "options": {
        "command": "../../../tools/clone_meetings_db.sh",
        "cwd": "{projectRoot}"
      }
    },
    "migrate-preview-db": {
      "executor": "nx:run-commands",
      "dependsOn": ["load-env-files"],
      "options": {
        "command": "gcloud run jobs deploy m-migrate-preview-db-$VERSION --image us-central1-docker.pkg.dev/recidiviz-dashboard-staging/meetings/meetings-server-preview:$VERSION --region us-central1 --execute-now --wait --command ./scripts/migrate-dbs.sh --set-env-vars DATABASE_USER=$DATABASE_USER,DATABASE_PASSWORD=$DATABASE_PASSWORD,DATABASE_INSTANCE_CONNECTION_NAME=$DATABASE_INSTANCE_CONNECTION_NAME,DATABASE_STATE_CODES=$DATABASE_STATE_CODES",
        "args": [
          "--project recidiviz-dashboard-staging",
          "--set-cloudsql-instances recidiviz-dashboard-staging:us-central1:s-db-preview-$VERSION",
          "--service-account meetings@recidiviz-dashboard-staging.iam.gserviceaccount.com"
        ]
      }
    },
    "deploy-preview-app": {
      "executor": "@nx-extend/gcp-cloud-run:deploy",
      "dependsOn": ["load-env-files", "migrate-db"],
      "options": {
        "name": "m-preview-$VERSION",
        "region": "us-central1",
        "project": "recidiviz-dashboard-staging",
        "image": "us-central1-docker.pkg.dev/recidiviz-dashboard-staging/meetings/meetings-server-preview:$VERSION",
        "cloudSqlInstance": "recidiviz-dashboard-staging:us-central1:s-db-preview-$VERSION",
        "memory": "512Mi",
        "envVars": {
          "AUTH0_DOMAIN": "$AUTH0_DOMAIN",
          "AUTH0_AUDIENCE": "$AUTH0_AUDIENCE",
          "SENTRY_DSN": "$SENTRY_DSN",
          "SENTRY_ENV": "$SENTRY_ENV",
          "IMPORT_BUCKET_ID": "$IMPORT_BUCKET_ID",
          "DATABASE_USER": "$DATABASE_USER",
          "DATABASE_PASSWORD": "$DATABASE_PASSWORD",
          "DATABASE_INSTANCE_CONNECTION_NAME": "$DATABASE_INSTANCE_CONNECTION_NAME"
        },
        "serviceAccount": "meetings@recidiviz-dashboard-staging.iam.gserviceaccount.com"
      }
    },
    "cleanup-preview-resources": {
      "executor": "nx:run-commands",
      "options": {
        "command": "../../../tools/cleanup_meetings_preview_resources.sh",
        "cwd": "{projectRoot}"
      }
    },
    "requires-sops-env:reprocess-meeting": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx scripts/reprocess-meeting-with-uploaded-audio.ts",
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "dev": {},
        "staging": {},
        "production": {}
      }
    }
  }
}
