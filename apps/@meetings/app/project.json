{
  "name": "@meetings/app",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/@meetings/app/src",
  "projectType": "application",
  "tags": ["scope:meetings", "type:app"],
  "// targets": "to see all targets run: nx show project @meetings/app --web",
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'No tests yet'"
      }
    },
    "load-env-file-gcp": {
      "executor": "nx:run-commands",
      "options": {
        "command": "../../../tools/load_env_files.sh --env env_meetings_app",
        "cwd": "{projectRoot}"
      }
    },
    "load-env-file-eas": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eas env:pull --non-interactive --path .env",
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "dev": {
          "args": "--environment development"
        },
        "preview": {
          "args": "--environment preview"
        },
        "production": {
          "args": "--environment production"
        }
      },
      "defaultConfiguration": "dev"
    },
    "offline:android": {
      "executor": "nx:run-commands",
      "dependsOn": ["load-env-file-gcp"],
      "options": {
        "commands": [
          "EXPO_NO_GIT_STATUS=1 nx prebuild @meetings/app --clean",
          "nx run-android @meetings/app --no-build-cache"
        ],
        "parallel": false
      },
      "cwd": "{workspaceRoot}"
    },
    "dev:android": {
      "executor": "nx:run-commands",
      "dependsOn": ["load-env-file-eas"],
      "options": {
        "commands": [
          "EXPO_NO_GIT_STATUS=1 nx prebuild @meetings/app --clean",
          "nx run-android @meetings/app --no-build-cache"
        ],
        "parallel": false
      },
      "cwd": "{workspaceRoot}"
    },
    "offline:ios": {
      "executor": "nx:run-commands",
      "dependsOn": ["load-env-file-gcp"],
      "options": {
        "commands": [
          "EXPO_NO_GIT_STATUS=1 nx prebuild @meetings/app --clean",
          "nx run-ios @meetings/app --no-build-cache"
        ],
        "parallel": false
      },
      "cwd": "{workspaceRoot}"
    },
    "dev:ios": {
      "executor": "nx:run-commands",
      "dependsOn": ["load-env-file-eas"],
      "options": {
        "commands": [
          "EXPO_NO_GIT_STATUS=1 nx prebuild @meetings/app --clean",
          "nx run-ios @meetings/app --no-build-cache"
        ],
        "parallel": false
      },
      "cwd": "{workspaceRoot}"
    }
  }
}
