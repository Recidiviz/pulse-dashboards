{
  "build": {
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "YARN_ENABLE_IMMUTABLE_INSTALLS": "false",
        "APP_ENV": "production"
      },
      "channel": "production",
      "environment": "production",
      "autoIncrement": true
    },
    "staging": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "YARN_ENABLE_IMMUTABLE_INSTALLS": "false",
        "APP_ENV": "staging"
      },
      "channel": "staging",
      "environment": "preview",
      "autoIncrement": true
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "preview"
      },
      "channel": "preview",
      "environment": "preview"
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_ENV": "development"
      },
      "channel": "development",
      "environment": "development"
    }
  },
  "submit": {
    "production": {}
  },
  "cli": {
    "appVersionSource": "remote"
  }
}
