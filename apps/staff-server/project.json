{
  "name": "staff-server",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/staff-server/src",
  "projectType": "application",
  "tags": ["scope:server"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "tsc -p ./tsconfig.app.json",
          "tsc -p ./tsconfig.spec.json"
        ],
        "cwd": "{projectRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/apps/staff-server"],
      "cache": true,
      "options": {
        "command": "vitest",
        "cwd": "{projectRoot}"
      }
    },
    "requires-sops-env:dev": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "redis-server --port 6380",
          "vite-node --watch src/server/index.js"
        ],
        "cwd": "{projectRoot}"
      },
      "configurations": { "development": {}, "demo": {} },
      "defaultConfiguration": "development"
    },
    "offline": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "redis-server --port 6380",
          "vite-node --watch src/server/index.js"
        ],
        "cwd": "{projectRoot}"
      }
    },
    "create-build-package-json": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["vite-node tools/createBuildPackageJson.ts"],
        "cwd": "{projectRoot}"
      }
    },
    "esbuild": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "cache": true,
      "options": {
        "platform": "node",
        "outputPath": "dist/apps/staff-server",
        "bundle": true,
        "format": ["esm"],
        "main": "{projectRoot}/src/server/index.js",
        "tsConfig": "{projectRoot}/tsconfig.app.json",
        "generatePackageJson": true,
        "assets": [
          {
            "input": "{projectRoot}/src",
            "glob": "server/assets/**/*",
            "output": "/"
          },
          "{workspaceRoot}/.yarnrc.yml"
        ],
        "target": "node22"
      },
      "configurations": {
        "deploy": {
          "esbuildConfig": "{projectRoot}/esbuild.deploy.config.js"
        },
        "e2e": {}
      },
      "defaultConfiguration": "deploy"
    },
    "build": {
      "dependsOn": ["create-build-package-json"],
      "command": "nx esbuild staff-server -c deploy && cd dist/apps/staff-server && yarn"
    },
    "build-e2e": {
      "executor": "nx:run-commands",
      "dependsOn": ["create-build-package-json"],
      "options": {
        "commands": [
          "nx esbuild staff-server -c e2e",
          "cp apps/staff-server/.env.offline dist/apps/staff-server"
        ],
        "parallel": false
      }
    },
    "pull-python-backend": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose pull case_triage_backend",
        "cwd": "{projectRoot}"
      }
    },
    "python-backend-offline": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sh tools/run_python_backend.sh",
        "cwd": "{projectRoot}"
      }
    },
    "python-backend-shutdown": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose down",
        "cwd": "{projectRoot}"
      }
    }
  }
}
