{
  "name": "@cpa/interview",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/@cpa/interview/src",
  "projectType": "application",
  "tags": ["cpa", "scope:client", "type:app"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["tsc -p ./tsconfig.app.json"],
        "cwd": "{projectRoot}"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["vite dev"],
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "executor": "@nx/vite:build",
      "cache": true,
      "options": {
        "outputPath": "{workspaceRoot}/dist/apps/@cpa/interview",
        "emptyOutDir": true
      }
    }
  }
}
