{
  "name": "@cpa/server",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/@cpa/server/src",
  "projectType": "application",
  "tags": ["cpa", "scope:server"],
  "targets": {
    "load-env-files": {
      "executor": "nx:run-commands",
      "options": {
        "command": "../../../tools/load_env_files.sh --env env_reentry_server --env_staging env_staging_reentry_server --env_test env_test_reentry_server",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "projects": ["@reentry/prisma"],
          "target": "prisma-generate"
        }
      ],
      "options": {
        "commands": [
          "tsc -p ./tsconfig.app.json",
          "tsc -p ./tsconfig.spec.json"
        ],
        "cwd": "{projectRoot}"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "checkpointer-setup",
        {
          "projects": ["@reentry/prisma"],
          "target": "docker"
        },
        {
          "projects": ["@reentry/prisma"],
          "target": "prisma-seed"
        }
      ],
      "options": {
        "command": "vite-node --watch src/main.ts",
        "cwd": "{projectRoot}"
      }
    },
    "create-base-package-json": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx tools/create-base-package-json.mts {projectRoot}",
        "cwd": "{workspaceRoot}"
      }
    },
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "dependsOn": [
        "create-base-package-json",
        {
          "projects": ["@reentry/prisma"],
          "target": "prisma-generate"
        },
        "load-env-files"
      ],
      "options": {
        "platform": "node",
        "outputPath": "{workspaceRoot}/dist/apps/{projectName}",
        "bundle": true,
        "main": "{projectRoot}/src/main.ts",
        "additionalEntryPoints": [
          "{projectRoot}/src/sentry/index.ts"
        ],
        "sourcemap": true,
        "tsConfig": "{projectRoot}/tsconfig.app.json",
        "generatePackageJson": true,
        "target": "node20",
        "minify": true,
        "external": ["@prisma/client"],
        "assets": [
          {
            "glob": "prisma/schema.prisma",
            "input": "{workspaceRoot}/libs/@reentry/prisma",
            "output": "."
          },
          {
            "glob": "prisma/migrations/**/*",
            "input": "{workspaceRoot}/libs/@reentry/prisma",
            "output": "."
          },
          "{projectRoot}/scripts/*",
          "{workspaceRoot}/.yarnrc.yml"
        ]
      },
      "configurations": {
        "dev": {
          "minify": false,
          "sourcemap": false
        },
        "staging": {},
        "cherry-pick": {},
        "preview": {},
        "demo": {}
      },
      "defaultConfiguration": "dev"
    },
    "preview": {
      "executor": "@nx/vite:preview-server",
      "dependsOn": [
        {
          "projects": ["@reentry/prisma"],
          "target": "docker"
        },
        {
          "projects": ["@reentry/prisma"],
          "target": "prisma-seed"
        },
        "build"
      ],
      "options": {
        "buildTarget": "@cpa/server:build"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "projects": ["@reentry/prisma"],
          "target": "prisma-generate"
        },
        {
          "projects": ["@reentry/prisma"],
          "target": "docker"
        }
      ],
      "outputs": ["{workspaceRoot}/coverage/apps/cpa"],
      "cache": true,
      "options": {
        "command": "nx prisma-deploy @reentry/prisma && cd apps/@cpa/server && vitest",
        "cwd": "{workspaceRoot}"
      }
    },
    "upload-sourcemaps": {},
    "container": {
      "executor": "@nx-tools/nx-container:build",
      "dependsOn": ["upload-sourcemaps"],
      "cwd": "{projectRoot}",
      "options": {
        "engine": "docker",
        "platforms": ["linux/amd64"]
      },
      "configurations": {
        "dev": {
          "push": false
        },
        "staging": {
          "push": true,
          "tags": [
            "us-central1-docker.pkg.dev/recidiviz-dashboard-staging/reentry/reentry-server:$COMMIT_SHA",
            "us-central1-docker.pkg.dev/recidiviz-dashboard-staging/reentry/reentry-server:latest"
          ]
        },
        "cherry-pick": {
          "push": true,
          "tags": [
            "us-central1-docker.pkg.dev/recidiviz-dashboard-staging/reentry/reentry-server:$COMMIT_SHA"
          ]
        },
        "preview": {
          "push": true,
          "tags": [
            "us-central1-docker.pkg.dev/recidiviz-dashboard-staging/reentry/reentry-server-preview:$VERSION"
          ]
        },
        "demo": {
          "push": true,
          "tags": [
            "us-central1-docker.pkg.dev/recidiviz-dashboard-staging/reentry/reentry-server:$COMMIT_SHA"
          ]
        }
      },
      "defaultConfiguration": "dev"
    }
  }
}
