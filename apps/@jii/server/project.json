{
  "name": "@jii/server",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/@jii/server/src",
  "projectType": "application",
  "tags": ["scope:server"],
  "targets": {
    "requires-sops-env:dev": {
      "continuous": true,
      "dependsOn": ["^prisma-generate", "^prisma-deploy", "jwks-sim"],
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "vite-node --watch src/main.ts"
      }
    },
    "offline": {
      "continuous": true,
      "dependsOn": ["^prisma-generate", "^prepare-offline-db"],
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "vite-node --watch src/main.ts"
      }
    },
    "jwks-sim": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "tsx watch src/tools/jwks-simulator/main.ts",
        "cwd": "{projectRoot}"
      }
    },
    "requires-sops-env:edovo-test-token": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx src/tools/edovoTestToken.ts",
        "cwd": "{projectRoot}"
      },
      "metadata": {
        "sops-env": {
          "additional-sops-env-files": ["{projectRoot}/env.dev.enc.yaml"]
        }
      }
    },
    "requires-sops-env:decode-token": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx src/tools/decodeJWE.ts",
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "staging": {},
        "production": {}
      },
      "defaultConfiguration": "production"
    },
    "requires-sops-env:decrypt-edovo-tokens": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx src/tools/decryptEdovoTokens.ts",
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "staging": {},
        "production": {}
      },
      "defaultConfiguration": "production"
    },
    "offline-e2e": {
      "continuous": true,
      "dependsOn": ["^prisma-generate", "^prepare-test-db"],
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "vite-node --watch src/main.ts"
      }
    },
    "create-base-package-json": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx tools/create-base-package-json.mts {projectRoot}",
        "cwd": "{workspaceRoot}"
      }
    },
    "requires-sops-env:build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "dependsOn": [
        "create-base-package-json",
        {
          "projects": ["@jii/prisma"],
          "target": "prisma-generate"
        }
      ],
      "options": {
        "platform": "node",
        "outputPath": "{workspaceRoot}/dist/apps/{projectName}",
        "bundle": true,
        "main": "{projectRoot}/src/main.ts",
        "additionalEntryPoints": ["{projectRoot}/src/sentry/index.ts"],
        "sourcemap": true,
        "tsConfig": "{projectRoot}/tsconfig.app.json",
        "generatePackageJson": true,
        "target": "node22",
        "minify": true,
        "esbuildConfig": "{projectRoot}/esbuild.config.js",
        "external": ["@prisma/client"],
        "assets": [
          {
            "glob": "prisma/schema.prisma",
            "input": "{workspaceRoot}/libs/@jii/prisma",
            "output": "."
          },
          {
            "glob": "prisma/migrations/**/*",
            "input": "{workspaceRoot}/libs/@jii/prisma",
            "output": "."
          },
          "{projectRoot}/scripts/*",
          "{workspaceRoot}/.yarnrc.yml"
        ]
      },
      "configurations": {
        "dev": {
          "minify": false,
          "sourcemap": false
        },
        "staging": {},
        "cherry-pick": {},
        "preview": {},
        "demo": {}
      },
      "defaultConfiguration": "dev"
    },
    "container": {
      "dependsOn": ["build"],
      "executor": "@nx-tools/nx-container:build",
      "cwd": "{projectRoot}",
      "options": {
        "engine": "docker",
        "platforms": ["linux/amd64"]
      },
      "configurations": {
        "dev": {
          "push": false
        },
        "staging": {
          "push": true,
          "tags": [
            "us-central1-docker.pkg.dev/recidiviz-jii-staging/jii/jii-server:$COMMIT_SHA",
            "us-central1-docker.pkg.dev/recidiviz-jii-staging/jii/jii-server:latest"
          ]
        },
        "cherry-pick": {
          "push": true,
          "tags": [
            "us-central1-docker.pkg.dev/recidiviz-jii-staging/jii/jii-server:$COMMIT_SHA"
          ]
        },
        "preview": {
          "push": true,
          "tags": [
            "us-central1-docker.pkg.dev/recidiviz-jii-staging/jii/jii-server-preview:$VERSION"
          ]
        },
        "demo": {
          "push": true,
          "tags": [
            "us-central1-docker.pkg.dev/recidiviz-jii-staging/jii/jii-server:$COMMIT_SHA"
          ]
        }
      },
      "defaultConfiguration": "dev"
    }
  }
}
