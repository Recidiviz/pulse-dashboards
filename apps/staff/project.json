{
  "name": "staff",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/staff/src",
  "projectType": "application",
  "tags": ["scope:client"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "dependsOn": ["^prisma-generate"],
      "options": {
        "commands": [
          "tsc -p ./tsconfig.app.json",
          "tsc -p ./tsconfig.spec.json"
        ],
        "cwd": "{projectRoot}"
      }
    },
    "examples": {
      "executor": "nx:run-commands",
      "options": {
        "command": "EXAMPLES_PATHS=\"{args}\" storybook dev --config-dir .examples",
        "cwd": "{projectRoot}"
      }
    },
    "build-examples": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/examples-static"],
      "options": {
        "command": "EXAMPLES_PATHS=\"{args}\" storybook build --config-dir .examples --output-dir examples-static",
        "cwd": "{projectRoot}"
      }
    },
    "requires-sops-env:test-e2e": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "wdio ./wdio.conf.js --retry 2"
      }
    },
    "requires-sops-env:test-zod": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "vite-node tools/testZodSchema.ts {args}"
      },
      "configurations": {
        "development": {}
      },
      "defaultConfiguration": "development",
      "metadata": {
        "sops-env": {
          "override-sops-env-project": "staff-server"
        }
      }
    },
    "requires-sops-env:dev-spa": {
      "executor": "nx:run-commands",
      "options": { "command": "vite dev --force", "cwd": "{projectRoot}" },
      "configurations": {
        "development": {}
      },
      "defaultConfiguration": "development"
    },
    "requires-sops-env:dev": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["nx dev-spa staff", "nx dev staff-server"]
      },
      "defaultConfiguration": "development",
      "configurations": {
        "development": {},
        "demo": {}
      }
    },
    "requires-sops-env:dev-be": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["nx dev-spa staff", "nx dev staff-server"]
      },
      "defaultConfiguration": "dev.local",
      "configurations": {
        "dev.local": {}
      }
    },
    "update-workflows-fixture": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "{projectRoot}/tools/**/*",
        "{workspaceRoot}/libs/datatypes/**/*"
      ],
      "outputs": [
        "{workspaceRoot}/dist/firestore-emulator-fixtures/apps/staff"
      ],
      "options": {
        "cwd": "{projectRoot}",
        "commands": [
          "mkdir -p ../../dist/firestore-emulator-fixtures/apps/staff",
          "firebase emulators:exec --project=demo-dev --only firestore --export-on-exit ../../dist/firestore-emulator-fixtures/apps/staff 'NODE_OPTIONS=\"--unhandled-rejections=strict\" vite-node --config vite.config.mts tools/loadWorkflowsFixtures.ts'"
        ],
        "parallel": false
      }
    },
    "firebase-offline": {
      "executor": "nx:run-commands",
      "dependsOn": ["update-workflows-fixture"],
      "options": {
        "command": "firebase --project=demo-dev emulators:start --only auth,firestore --import ../../dist/firestore-emulator-fixtures/apps/staff",
        "cwd": "{projectRoot}"
      }
    },
    "offline": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "vite dev",
          "cd ../../ && nx firebase-offline staff",
          "cd ../../ && nx offline staff-server",
          "cd ../../ && nx offline '@typesense/tools'",
          "cd ../../ && nx offline-sync '@typesense/tools'"
        ],
        "cwd": "{projectRoot}"
      }
    },
    "offline-python": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx offline staff",
          "nx python-backend-offline staff-server"
        ],
        "cwd": "{workspaceRoot}"
      }
    },
    "requires-sops-env:build": {
      "executor": "@nx/vite:build",
      "dependsOn": ["^prisma-generate"],
      "options": {
        "outputPath": "{workspaceRoot}/dist/apps/staff"
      },
      "configurations": {
        "development": {},
        "demo": {},
        "staging": {},
        "production": {}
      }
    },
    "requires-sops-env:build-e2e": {
      "executor": "@nx/vite:build",
      "dependsOn": ["^prisma-generate"],
      "options": {
        "outputPath": "{workspaceRoot}/dist/apps/staff"
      },
      "metadata": {
        "sops-env": {
          "additional-dotenv-files": ["{projectRoot}/.env.offline"]
        }
      }
    },
    "requires-sops-env:verify-feature-variant-documentation": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "vite-node tools/verifyFeatureVariantDocumentation.ts"
      }
    },
    "requires-sops-env:load-demo-fixtures": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "vite-node tools/loadWorkflowsFixtures.ts"
      },
      "configurations": {
        "staging": {},
        "production": {}
      }
    },
    "pdfformfiller-boilerplate": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "vite-node tools/pdfFormFillerBoilerplate.mjs"
      }
    },
    "requires-sops-env:delete-data-from-state": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "vite-node tools/deleteDataFromState.ts {args.stateCode}"
      },
      "configurations": {
        "staging": {},
        "production": {}
      }
    }
  }
}
