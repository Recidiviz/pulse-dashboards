{
  "name": "public-pathways",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/public-pathways/src",
  "projectType": "application",
  "tags": ["scope:client", "type:app"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "tsc -p ./tsconfig.app.json",
          "tsc -p ./tsconfig.spec.json"
        ],
        "cwd": "{projectRoot}"
      }
    },
    "requires-sops-env:dev": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["vite dev"],
        "cwd": "{projectRoot}"
      }
    },
    "requires-sops-env:build": {
      "executor": "@nx/vite:build",
      "cache": true,
      "options": {
        "outputPath": "{workspaceRoot}/dist/apps/public-pathways",
        "emptyOutDir": true
      },
      "configurations": {
        "staging": {
          "mode": "staging"
        },
        "production": {
          "mode": "production"
        }
      },
      "defaultConfiguration": "staging"
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite preview --outDir ../../dist/apps/public-pathways",
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "staging": {},
        "production": {}
      },
      "defaultConfiguration": "staging",
      "dependsOn": [{ "target": "build", "params": "forward" }]
    },
    "deploy": {
      "dependsOn": [{ "target": "build", "params": "forward" }],
      "command": "firebase deploy --config firebase.public-pathways.json",
      "configurations": {
        "staging": {
          "args": "--project public-pathways-staging --only hosting:live"
        },
        "production": {
          "args": "--project public-pathways-production --only hosting:live"
        }
      },
      "defaultConfiguration": "staging"
    },
    "deploy-preview": {
      "dependsOn": [{ "target": "build", "params": "forward" }],
      "command": "firebase --config firebase.public-pathways.json hosting:channel:deploy",
      "configurations": {
        "staging": {
          "args": "--project public-pathways-staging --only live"
        },
        "production": {
          "args": "--project public-pathways-production --only live"
        }
      },
      "defaultConfiguration": "staging"
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/apps/public-pathways"],
      "cache": true,
      "options": {
        "command": "vitest",
        "cwd": "{projectRoot}"
      }
    }
  }
}
