{
  "name": "case-notes-server",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/case-notes-server/src",
  "projectType": "application",
  "tags": ["scope:server"],
  "targets": {
    "local": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx src/tools/local/index.ts",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "tsc -p ./tsconfig.app.json",
          "tsc -p ./tsconfig.spec.json"
        ],
        "cwd": "{projectRoot}"
      }
    },
    "requires-sops-env:dev": {
      "executor": "nx:run-commands",
      "dependsOn": ["docker"],
      "options": {
        "command": "vite-node --watch src/main.ts",
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "dependsOn": ["create-base-package-json"],
      "options": {
        "platform": "node",
        "outputPath": "{workspaceRoot}/dist/apps/{projectName}",
        "bundle": true,
        "main": "{projectRoot}/src/main.ts",
        "additionalEntryPoints": ["{projectRoot}/src/sentry/index.ts"],
        "sourcemap": true,
        "tsConfig": "{projectRoot}/tsconfig.app.json",
        "generatePackageJson": true,
        "target": "node22",
        "minify": true,
        "assets": ["{workspaceRoot}/.yarnrc.yml"]
      },
      "configurations": {
        "dev": {
          "minify": false,
          "sourcemap": false
        },
        "staging": {},
        "cherry-pick": {},
        "demo": {}
      },
      "defaultConfiguration": "dev"
    },
    "preview": {
      "executor": "@nx/vite:preview-server",
      "dependsOn": ["docker", "build"],
      "options": {
        "buildTarget": "case-notes-server:build"
      }
    },
    "requires-sops-env:test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/apps/case-notes-server"],
      "cache": true,
      "options": {
        "command": "vitest",
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "dev": {},
        "test": {}
      }
    },
    "requires-sops-env:upload-sourcemaps": {},
    "container": {
      "executor": "@nx-tools/nx-container:build",
      "dependsOn": ["upload-sourcemaps"],
      "options": {
        "engine": "docker",
        "platforms": ["linux/amd64"]
      },
      "configurations": {
        "dev": {
          "push": false
        },
        "staging": {
          "push": true,
          "tags": [
            "us-central1-docker.pkg.dev/recidiviz-dashboard-staging/case-notes/case-notes-server:$COMMIT_SHA",
            "us-central1-docker.pkg.dev/recidiviz-dashboard-staging/case-notes/case-notes-server:latest"
          ]
        },
        "cherry-pick": {
          "push": true,
          "tags": [
            "us-central1-docker.pkg.dev/recidiviz-dashboard-staging/case-notes/case-notes-server:$COMMIT_SHA"
          ]
        },
        "demo": {
          "push": true,
          "tags": [
            "us-central1-docker.pkg.dev/recidiviz-dashboard-staging/case-notes/case-notes-server:$COMMIT_SHA"
          ]
        }
      },
      "defaultConfiguration": "dev"
    }
  }
}
