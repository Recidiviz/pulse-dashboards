{
  "name": "@jii-texting/utils",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/@jii-texting/utils/src",
  "projectType": "library",
  "metadata": {
    "sops-env": {
      "override-sops-env-project": "@jii-texting/server"
    }
  },
  "tags": ["jii-texting", "scope:server"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "projects": ["@jii-texting/prisma"],
          "target": "prisma-generate"
        }
      ],
      "options": {
        "commands": [
          "tsc -p ./tsconfig.lib.json",
          "tsc -p ./tsconfig.spec.json"
        ],
        "cwd": "{projectRoot}"
      }
    },
    "requires-sops-env:test": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "projects": ["@jii-texting/prisma"],
          "target": "custom-prisma-deploy"
        }
      ],
      "outputs": ["{workspaceRoot}/coverage/libs/@jii-texting/utils"],
      "cache": true,
      "options": {
        "command": "vitest",
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "dev": {},
        "test": {}
      }
    }
  }
}
