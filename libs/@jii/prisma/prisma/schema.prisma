generator client {
    provider   = "prisma-client"
    output     = "../src/client"
    engineType = "client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// can be used to store random bits of user activity or preferences
model UserProperties {
    id                String    @id
    hasSeenOnboarding DateTime?
}

// US_NE reentry checklist questions
model usNeReentryChecklistQuestion {
    pseudonymizedId String
    questionId      String
    value           Boolean
    updatedAt       DateTime @updatedAt

    @@id([pseudonymizedId, questionId])
}
