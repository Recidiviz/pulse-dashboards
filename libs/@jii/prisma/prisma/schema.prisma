generator client {
    provider   = "prisma-client"
    output     = "../src/client"
    engineType = "client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// can be used to store random bits of user activity or preferences
model UserProperties {
    id                String    @id
    hasSeenOnboarding DateTime?
}

// Resident Flags tell the frontend to behave differently for specific residents
// during testing or rollouts. This enum defines the set of flags that can be set.
enum ResidentFlagId {
    usNeGoodTimeAlerts
}

model ResidentFlagInstance {
    pseudonymizedId String
    flagId          ResidentFlagId
    effectiveAt     DateTime

    @@id([pseudonymizedId, flagId])
}

////////////////////////////////////////////////////////
// Models intended to be state-specific follow
////////////////////////////////////////////////////////

// US_CO (Colorado)

// Tracks programs that a user has starred/favorited in Colorado
model UsCoStarredProgram {
    pseudonymizedId String
    programId       String
    title           String
    createdAt       DateTime @default(now())

    @@id([pseudonymizedId, programId, title])
}

// US_NC (North Carolina)

// An instance of an RNA survey for North Carolina
model UsNcRNA {
    // internal identifier for this survey
    id String @unique @default(cuid())

    pseudonymizedId    String
    createdAt          DateTime  @default(now())
    enabledAt          DateTime?
    updatedAt          DateTime  @updatedAt
    completedAt        DateTime?
    submittedByStaffAt DateTime?

    // The resident's answers, parsed via Zod
    answers Json
}

// US_NE (Nebraska) reentry checklist questions
model usNeReentryChecklistQuestion {
    pseudonymizedId String
    questionId      String
    value           Boolean
    updatedAt       DateTime @updatedAt

    @@id([pseudonymizedId, questionId])
}
