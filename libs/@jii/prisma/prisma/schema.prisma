generator client {
    provider   = "prisma-client"
    output     = "../src/client"
    engineType = "client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// can be used to store random bits of user activity or preferences
model UserProperties {
    id                String    @id
    hasSeenOnboarding DateTime?
}

////////////////////////////////////////////////////////
// Models intended to be state-specific follow
////////////////////////////////////////////////////////

// US_CO (Colorado)

// Tracks programs that a user has starred/favorited in Colorado
model UsCoStarredProgram {
    pseudonymizedId String
    programId       String
    title           String
    createdAt       DateTime @default(now())

    @@id([pseudonymizedId, programId, title])
}

// US_NC (North Carolina)

// An instance of an RNA survey for North Carolina
model UsNcRNA {
    // internal identifier for this survey
    id              String      @unique @default(cuid())

    pseudonymizedId String
    updatedAt       DateTime    @updatedAt
    completed       Boolean     @default(false)

    // The resident's answers, parsed via Zod
    answers         Json
}

// US_NE (Nebraska) reentry checklist questions
model usNeReentryChecklistQuestion {
    pseudonymizedId String
    questionId      String
    value           Boolean
    updatedAt       DateTime @updatedAt

    @@id([pseudonymizedId, questionId])
}
