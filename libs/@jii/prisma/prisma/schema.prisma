generator client {
    provider   = "prisma-client"
    output     = "../src/client"
    engineType = "client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// can be used to store random bits of user activity or preferences
model UserProperties {
    id                String   @id
    hasSeenOnboarding Boolean?
}
