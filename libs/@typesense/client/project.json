{
  "name": "@typesense/client",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/@typesense/client/src",
  "projectType": "library",
  "tags": ["scope:universal"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "tsc -p ./tsconfig.lib.json",
          "tsc -p ./tsconfig.spec.json"
        ],
        "cwd": "{projectRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/libs/@typesense/client"],
      "cache": true,
      "options": {
        "command": "vitest",
        "cwd": "{projectRoot}"
      }
    },
    "requires-sops-env:collection-list": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx src/inspect.ts list",
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "offline": {},
        "staging": {},
        "production": {}
      }
    },
    "requires-sops-env:collection-summary": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx src/inspect.ts summary",
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "offline": {},
        "staging": {},
        "production": {}
      }
    },
    "requires-sops-env:collection-schema": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx src/inspect.ts schema --collection={args.collection}",
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "offline": {},
        "staging": {},
        "production": {}
      }
    }
  }
}
