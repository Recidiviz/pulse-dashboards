{
  "name": "@reentry/intake-agent",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/@reentry/intake-agent/src",
  "projectType": "library",
  "metadata": {
    "sops-env": {
      "override-sops-env-project": "@cpa/server"
    }
  },
  "tags": ["reentry", "scope:server"],
  "targets": {
    "requires-sops-env:local": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "projects": ["@reentry/prisma"],
          "target": "docker"
        }
      ],
      "options": {
        "command": "tsx local/index.ts",
        "cwd": "{projectRoot}"
      }
    },
    "mermaid": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx local/mermaid.ts",
        "cwd": "{projectRoot}"
      }
    },
    "evaluate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx evaluate/index.ts",
        "cwd": "{projectRoot}"
      }
    },
    "langgraph": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "npx @langchain/langgraph-cli dev"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "tsc -p ./tsconfig.lib.json",
          "tsc -p ./tsconfig.spec.json",
          "tsc -p ./tsconfig.local.json"
        ],
        "cwd": "{projectRoot}"
      }
    },
    "docker": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "dev": {
          "command": "docker compose up --wait"
        },
        "test": {
          "command": "echo 'No docker for CI'"
        }
      },
      "defaultConfiguration": "dev"
    }
  }
}
