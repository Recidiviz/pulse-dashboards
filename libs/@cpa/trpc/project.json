{
  "name": "@cpa/trpc",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/@cpa/trpc/src",
  "projectType": "library",
  "metadata": {
    "sops-env": {
      "override-sops-env-project": "@cpa/server"
    }
  },
  "tags": ["cpa", "scope:server"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
