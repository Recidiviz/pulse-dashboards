{
  "name": "@meetings/trpc",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/@meetings/trpc/src",
  "projectType": "library",
  "tags": ["meetings", "scope:server"],
  "metadata": {
    "sops-env": {
      "override-sops-env-project": "@meetings/server"
    }
  },
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "tsc -p ./tsconfig.lib.json",
          "tsc -p ./tsconfig.spec.json"
        ],
        "cwd": "{projectRoot}"
      }
    },
    "requires-sops-env:test": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "projects": ["@meetings/prisma"],
          "target": "prisma-generate"
        },
        {
          "projects": ["@meetings/prisma"],
          "target": "docker"
        },
        {
          "projects": ["@meetings/prisma"],
          "target": "prisma-deploy"
        }
      ],
      "outputs": ["{workspaceRoot}/coverage/libs/@meetings/trpc"],
      "cache": true,
      "options": {
        "command": "vitest",
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "dev": {},
        "ci": {},
        "test": {}
      }
    }
  }
}
