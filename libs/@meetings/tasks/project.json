{
  "name": "@meetings/tasks",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/@meetings/tasks/src",
  "projectType": "library",
  "tags": ["scope:server"],
  "metadata": {
    "sops-env": {
      "override-sops-env-project": "@meetings/server"
    }
  },
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "tsc -p ./tsconfig.lib.json",
          "tsc -p ./tsconfig.spec.json"
        ],
        "cwd": "{projectRoot}"
      }
    }
  }
}
