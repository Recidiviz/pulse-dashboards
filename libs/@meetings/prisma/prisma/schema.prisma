generator client {
  provider   = "prisma-client"
  output     = "../src/client"
  engineType = "client"
}

generator json {
  provider = "prisma-json-types-generator"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StateCode {
  US_AL
  US_AK
  US_AZ
  US_AR
  US_CA
  US_CO
  US_CT
  US_DE
  US_FL
  US_GA
  US_HI
  US_ID
  US_IL
  US_IN
  US_IA
  US_KS
  US_KY
  US_LA
  US_ME
  US_MD
  US_MA
  US_MI
  US_MN
  US_MS
  US_MO
  US_MT
  US_NE
  US_NV
  US_NH
  US_NJ
  US_NM
  US_NY
  US_NC
  US_ND
  US_OH
  US_OK
  US_OR
  US_PA
  US_RI
  US_SC
  US_SD
  US_TN
  US_TX
  US_UT
  US_VT
  US_VA
  US_WA
  US_WV
  US_WI
  US_WY
}

model Staff {
  stateCode StateCode
  // Explanation of ids:
  // - staffId: Unique identifier for the staff member in the system. This is not necessarily stable over time.
  // - stableStaffExternalId: A stable identifier that is an external identifier for the staff member, such as an employee ID.
  // - stableStaffExternalIdType: The type of the stable external identifier, such as "employee_id" or "contractor_id".
  // - pseudonymizedId: A unique identifier that is used to anonymize the staff member's identity in the system. It is a hashing of the stableStaffExternalId

  staffId               BigInt @id
  stableStaffExternalId String @unique
  pseudonymizedId       String @unique

  givenNames  String
  middleNames String?
  surname     String
  suffix      String?

  email    String?
  clients  ClientsToStaff[]
  meetings Meeting[]

  // Whether or not the staff appeared in the most recent export. Needed to ensure we don't delete
  // meetings when staff are removed.
  isActive Boolean @default(true)
}

model Client {
  stateCode StateCode

  // Unique identifier for the client in the system. This is not necessarily stable over time.
  personId                   BigInt @id
  // A mostly-stable identifier that is an external identifier for the client. In rare circumstances, this can change within a stablePersonExternalIdType, but we can consider it to be "stable enough".
  stablePersonExternalId     String
  // The type of the stable external identifier. Typically there will be only one per state at any given time, but there can be multiple if, for example, the state is doing an OMS migration
  stablePersonExternalIdType String
  // An identifier that is used to anonymize the client's identity in the system. It is a hashing of the stablePersonExternalId and thus is unique within a stablePersonExternalIdType.
  pseudonymizedId            String
  // An identifier that staff are used to using to refer to the client, which may be different from the stablePersonExternalId. This is used for display purposes in the UI.
  displayPersonExternalId    String

  givenNames  String
  middleNames String?
  surname     String
  suffix      String?

  supervisionType String

  staff    ClientsToStaff[]
  meetings Meeting[]

  // Whether or not the client appeared in the most recent export. Needed to ensure we don't delete
  // meetings when clients are removed.
  isActive Boolean @default(true)

  @@unique([stablePersonExternalId, stablePersonExternalIdType])
  @@unique([pseudonymizedId, stablePersonExternalIdType])
}

model ClientsToStaff {
  staff    Staff  @relation(fields: [staffId], references: [staffId])
  staffId  BigInt
  Client   Client @relation(fields: [clientId], references: [personId])
  clientId BigInt

  @@id([staffId, clientId])
}

model Resident {
  stateCode StateCode

  // Unique identifier for the resident in the system. This is not necessarily stable over time.
  personId                   BigInt @id
  // A mostly-stable identifier that is an external identifier for the resident. In rare circumstances, this can change within a stablePersonExternalIdType, but we can consider it to be "stable enough".
  stablePersonExternalId     String
  // The type of the stable external identifier. Typically there will be only one per state at any given time, but there can be multiple if, for example, the state is doing an OMS migration
  stablePersonExternalIdType String
  // An identifier that is used to anonymize the resident's identity in the system. It is a hashing of the stablePersonExternalId and thus is unique within a stablePersonExternalIdType.
  pseudonymizedId            String
  // An identifier that staff are used to using to refer to the resident, which may be different from the stablePersonExternalId. This is used for display purposes in the UI.
  displayPersonExternalId    String

  givenNames  String
  middleNames String?
  surname     String
  suffix      String?

  facilityId String

  meetings Meeting[]

  // Whether or not the resident appeared in the most recent export. Needed to ensure we don't delete
  // meetings when residents are removed.
  isActive Boolean @default(true)

  @@unique([stablePersonExternalId, stablePersonExternalIdType])
  @@unique([pseudonymizedId, stablePersonExternalIdType])
}

enum PostMeetingProcessingStatus {
  NOT_STARTED
  STITCHING_QUEUED
  STITCHING_IN_PROGRESS
  STITCHING_ERROR
  TRANSCRIPTION_QUEUED
  TRANSCRIPTION_IN_PROGRESS
  TRANSCRIPTION_ERROR
  NOTETAKING_QUEUED
  NOTETAKING_IN_PROGRESS
  NOTETAKING_ERROR
  COMPLETED
}

model Meeting {
  id String @id @default(cuid())

  startTime DateTime
  endTime   DateTime?

  recordingsGCSBucket   String
  recordingsFolderPath  String
  finalRecordingGCSPath String?

  postMeetingProcessingStatus PostMeetingProcessingStatus @default(NOT_STARTED)

  userNotepadNotes            String?
  caseNote         String?
  actionItems      String?
  criticalUpdates  String?
  meetingSummary   String?

  transcriptions Transcription[]

  // Meetings must occur with either a Client or Resident, but since we don't have a way to specify
  // oneof, make these relations optional
  client   Client? @relation(fields: [clientId], references: [personId])
  clientId BigInt?

  resident   Resident? @relation(fields: [residentId], references: [personId])
  residentId BigInt?

  // Recidiviz users don't appear in the staff table and should still be able to create meetings, so
  // make this relation optional.
  staff   Staff?  @relation(fields: [staffId], references: [staffId])
  staffId BigInt?
}

enum TranscriptionProvider {
  ASSEMBLYAI
  DEEPGRAM
}

model Transcription {
  id String @id @default(cuid())

  provider         TranscriptionProvider
  // The transcript response, stored as a JSON object. We store the whole object because its possible we may want to use other fields in the future.
  /// [TranscriptType]
  transcriptObject Json
  confidence       Float?
  utterances       Utterance[]
  summary          String?

  meeting   Meeting? @relation(fields: [meetingId], references: [id])
  meetingId String?

  @@unique([provider, meetingId])
}

model Utterance {
  id String @id @default(cuid())

  text        String
  speaker     String
  startTimeMs Int
  endTimeMs   Int
  confidence  Float

  transcription   Transcription @relation(fields: [transcriptionId], references: [id])
  transcriptionId String
}

enum NotetakingPipelineStatus {
  SUCCESS
  PARTIAL_FAILURE
  FAILURE
  IN_PROGRESS
}

enum NotetakingAgentType {
  EXTRACTION
  DRAFTING
  VERIFICATION
}

model NotetakingPipelineRun {
  id String @id @default(cuid())

  createdAt DateTime @default(now())

  // This is intentionally not stored as a foreign key
  // We want a full historical log of pipeline runs, even when the upstream meeting gets deleted
  meetingId            String
  langsmithTraceId     String?
  personPseudonymizedId String

  status NotetakingPipelineStatus

  /// [ErrorDetails]
  errorDetails Json?

  agentExecutions NotetakingAgentExecution[]
}

model NotetakingAgentExecution {
  id String @id @default(cuid())

  createdAt DateTime @default(now())

  pipelineRun   NotetakingPipelineRun @relation(fields: [pipelineRunId], references: [id])
  pipelineRunId String

  agentType     NotetakingAgentType
  attemptNumber Int                 @default(1)

  /// [AgentOutput]
  outputData Json

  /// [ValidationResult]
  validationResult Json

  @@index([pipelineRunId])
}
