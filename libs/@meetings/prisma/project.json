{
  "name": "@meetings/prisma",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/@meetings/prisma/src",
  "projectType": "library",
  "tags": ["meetings", "scope:server"],
  "metadata": {
    "sops-env": {
      "override-sops-env-project": "@meetings/server"
    }
  },
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "dependsOn": ["prisma-generate"],
      "options": {
        "commands": [
          "tsc -p ./tsconfig.app.json",
          "tsc -p ./tsconfig.spec.json"
        ],
        "cwd": "{projectRoot}"
      }
    },
    "requires-sops-env:test": {
      "executor": "nx:run-commands",
      "dependsOn": ["prisma-generate"],
      "outputs": ["{workspaceRoot}/coverage/libs/@meetings/prisma"],
      "cache": true,
      "options": {
        "command": "vitest",
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "test": {}
      }
    },
    "docker": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "dev": {
          "command": "docker compose up --wait"
        },
        "ci": { "command": "echo 'No docker for CI'" },
        "test": { "command": "echo 'No docker for CI'" }
      },
      "defaultConfiguration": "dev"
    },
    "requires-sops-env:prisma": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["yarn prisma"],
        "forwardAllArgs": true,
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "dev": {},
        "test": {}
      },
      "defaultConfiguration": "dev"
    },
    "prisma-generate": {
      "inputs": ["{projectRoot}/prisma/schema.prisma"],
      "executor": "@nx-tools/nx-prisma:generate",
      "options": {
        "schema": "{projectRoot}/prisma/schema.prisma"
      },
      "configurations": {
        "dev": {},
        "test": {}
      },
      "defaultConfiguration": "dev"
    },
    "requires-sops-env:prisma-format": {
      "executor": "@nx-tools/nx-prisma:format",
      "options": {
        "schema": "{projectRoot}/prisma/schema.prisma"
      },
      "configurations": {
        "dev": {},
        "test": {}
      },
      "defaultConfiguration": "dev"
    },
    "requires-sops-env:prisma-migrate": {
      "dependsOn": ["docker"],
      "executor": "@nx-tools/nx-prisma:migrate",
      "options": {
        "schema": "{projectRoot}/prisma/schema.prisma"
      },
      "configurations": {
        "dev": {},
        "test": {}
      },
      "defaultConfiguration": "dev"
    },
    "requires-sops-env:prisma-pull": {
      "executor": "@nx-tools/nx-prisma:pull",
      "options": {
        "schema": "{projectRoot}/prisma/schema.prisma"
      },
      "configurations": {
        "dev": {},
        "test": {}
      },
      "defaultConfiguration": "dev"
    },
    "requires-sops-env:prisma-push": {
      "executor": "@nx-tools/nx-prisma:push",
      "dependsOn": ["docker"],
      "options": {
        "schema": "{projectRoot}/prisma/schema.prisma"
      },
      "configurations": {
        "dev": {},
        "test": {}
      },
      "defaultConfiguration": "dev"
    },
    "requires-sops-env:prisma-deploy": {
      "executor": "@nx-tools/nx-prisma:deploy",
      "options": {
        "schema": "{projectRoot}/prisma/schema.prisma"
      },
      "configurations": {
        "dev": {},
        "test": {}
      },
      "defaultConfiguration": "dev"
    },
    "requires-sops-env:prisma-status": {
      "executor": "@nx-tools/nx-prisma:status",
      "options": {
        "schema": "{projectRoot}/prisma/schema.prisma"
      },
      "configurations": {
        "dev": {},
        "test": {}
      },
      "defaultConfiguration": "dev"
    },
    "requires-sops-env:prisma-studio": {
      "executor": "@nx-tools/nx-prisma:studio",
      "options": {
        "schema": "{projectRoot}/prisma/schema.prisma"
      },
      "configurations": {
        "dev": {},
        "test": {}
      },
      "defaultConfiguration": "dev"
    },
    "requires-sops-env:prisma-reset": {
      "executor": "@nx-tools/nx-prisma:reset",
      "options": {
        "schema": "{projectRoot}/prisma/schema.prisma"
      },
      "configurations": {
        "dev": {},
        "test": {}
      },
      "defaultConfiguration": "dev"
    },
    "requires-sops-env:prisma-resolve": {
      "executor": "@nx-tools/nx-prisma:resolve",
      "options": {
        "schema": "{projectRoot}/prisma/schema.prisma"
      },
      "configurations": {
        "dev": {},
        "test": {}
      },
      "defaultConfiguration": "dev"
    },
    "requires-sops-env:prisma-seed": {
      "executor": "nx:run-commands",
      "dependsOn": ["docker", "prisma-deploy", "prisma-generate"],
      "options": {
        "command": "tsx src/run-seed.ts",
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "dev": {},
        "test": {}
      },
      "defaultConfiguration": "dev"
    },
    "requires-sops-env:prisma-validate": {
      "executor": "@nx-tools/nx-prisma:validate",
      "options": {
        "schema": "{projectRoot}/prisma/schema.prisma"
      },
      "configurations": {
        "dev": {},
        "test": {}
      },
      "defaultConfiguration": "dev"
    }
  }
}
