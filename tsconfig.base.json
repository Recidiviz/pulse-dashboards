      "~datatypes": ["libs/datatypes/src/index.ts"],
      "~design-system": ["libs/design-system/src/index.ts"],
      "~firestore-api": ["libs/firestore-api/src/index.ts"],
      "~firestore-config": ["libs/firestore-config/src/index.ts"],
      "~fixture-generator": ["libs/fixture-generator/src/index.ts"],
      "~hydration-utils": ["libs/hydration-utils/src/index.ts"],
      "~repo": ["plugins/repo/src/index.ts"],
      "~sentencing-client": ["libs/sentencing-client/src/index.ts"],
      "~server-setup-plugin": ["libs/common/server-setup-plugin/src/index.ts"],
      "~server-setup-plugin/*": ["libs/common/server-setup-plugin/src/*"],
      "~shared-assets/*": ["libs/shared-assets/src/*"],
      "~staff-shared-server": ["libs/staff-shared-server/src/index.ts"],
      "~twilio-api": ["libs/twilio-api/src/index.ts"],
      "~ui": ["libs/ui/src/index.ts"],
      "~utils": ["libs/utils/src/index.ts"]
    },
    "resolveJsonModule": true,
    "rootDir": ".",
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2022",
    "useDefineForClassFields": true
  },
  "exclude": ["node_modules", "tmp"]
}
