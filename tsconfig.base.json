      "~@reentry/prisma/*": ["libs/@reentry/prisma/src/*"],
      "~@reentry/prisma/client": ["libs/@reentry/prisma/src/client/client.ts"],
      "~@reentry/server/*": ["apps/@reentry/server/src/*"],
      "~@reentry/server/test/*": ["apps/@reentry/server/__tests__/*"],
      "~@reentry/trpc": ["libs/@reentry/trpc/src/index.ts"],
      "~@reentry/trpc-types": ["libs/@reentry/trpc-types/src/index.ts"],
      "~@reentry/trpc/*": ["libs/@reentry/trpc/src/*"],
      "~@reentry/trpc/test/*": ["libs/@reentry/trpc/__tests__/*"],
      "~@sentencing/import": ["apps/@sentencing/import/src/index.ts"],
      "~@sentencing/import/*": ["apps/@sentencing/import/src/*"],
      "~@sentencing/import/test/*": ["apps/@sentencing/import/__tests__/*"],
      "~@sentencing/prisma": ["libs/@sentencing/prisma/src/index.ts"],
      "~@sentencing/prisma/*": ["libs/@sentencing/prisma/src/*"],
      "~@sentencing/prisma/client": [
        "libs/@sentencing/prisma/src/client/client.ts"
      ],
      "~@sentencing/server/*": ["apps/@sentencing/server/src/*"],
      "~@sentencing/server/test/*": ["apps/@sentencing/server/__tests__/*"],
      "~@sentencing/trpc": ["libs/@sentencing/trpc/src/index.ts"],
      "~@sentencing/trpc-types": ["libs/@sentencing/trpc-types/src/index.ts"],
      "~@sentencing/trpc/*": ["libs/@sentencing/trpc/src/*"],
      "~auth": ["libs/auth/src/index.ts"],
      "~case-notes-server/*": ["apps/case-notes-server/src/*"],
      "~client-env-utils": ["libs/client-env-utils/src/index.ts"],
      "~data-import-plugin": ["libs/common/data-import-plugin/src/index.ts"],
