      "~@jii/auth": ["libs/@jii/auth/src/index.ts"],
      "~@jii/case-planning": ["libs/@jii/case-planning/src/index.ts"],
      "~@jii/common-ui": ["libs/@jii/common-ui/src/index.ts"],
