{
  "name": "repo",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "plugins/repo/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "tsc -p ./tsconfig.lib.json --noEmit",
            "forwardAllArgs": false
          }
        ],
        "cwd": "{projectRoot}"
      }
    }
  }
}
